// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
  previewFeatures = ["postgresqlExtensions"]
}

generator erd {
  provider = "prisma-erd-generator"
  output   = "./ERD.svg"
}

datasource db {
  provider = "postgresql"
  extensions = [pgcrypto]
}

enum Role {
  ADMIN
  USER
}

enum BookStatus {
  AVAILABLE
  BORROWED
  LOST
  REMOVED
}

enum BorrowingStatus {
  ACTIVE
  RETURNED
  OVERDUE
}

model User {
  id              String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email           String          @unique
  passwordHash    String
  role            Role            @default(USER)
  firstName       String?
  lastName        String?
  isActive        Boolean         @default(true)

  refreshSessions RefreshSession[]
  borrowings      Borrowing[]
  reviews         Review[]

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @default(now())
  lastLoginAt     DateTime?
}

model RefreshSession {
  id              String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  userId          String          @db.Uuid
  User            User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  tokenHash       String

  revokedAt       DateTime?

  replacedById    String? @unique @db.Uuid @map("replaced_by_id")
  replacedBy      RefreshSession? @relation("RefreshRotation", fields: [replacedById], references: [id])
  replaces        RefreshSession? @relation("RefreshRotation")

  userAgent       String?
  ip              String?

  createdAt       DateTime        @default(now())
  expiresAt       DateTime

  @@index([userId])
  @@index([expiresAt])
}

model Author {
  id                  String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  firstName           String
  lastName            String
  normalizedFirstName String
  normalizedLastName  String

  books               BookAuthor[]

  isActive            Boolean     @default(true)
  deletedAt           DateTime?

  updatedAt           DateTime    @updatedAt
  createdAt           DateTime    @default(now())

  @@unique([normalizedFirstName, normalizedLastName])
}

model BookAuthor {
  bookId          String          @db.Uuid
  authorId        String          @db.Uuid

  book            Book            @relation(fields: [bookId], references: [id], onDelete: Cascade)
  author          Author          @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@id([bookId, authorId])
  @@index([authorId])
}

model Book {
  id              String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title           String
  subtitle        String?
  description     String? 
  isbn            String          @unique
  publicationYear Int
  language        String
  coverImageUrl   String?

  categoryId      String          @db.Uuid
  category        Category        @relation(fields: [categoryId], references: [id])

  authors         BookAuthor[]
  copies          BookCopy[]
  reviews         Review[]

  isActive        Boolean         @default(true)
  deletedAt       DateTime?

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

model BookCopy {
  id              String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  bookId          String          @db.Uuid
  book            Book            @relation(fields: [bookId], references: [id], onDelete: Cascade)

  inventoryNumber String          @unique
  status          BookStatus      @default(AVAILABLE)

  borrowings      Borrowing[]

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([bookId])
}

model Category {
  id              String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name            String          
  normalizedName  String          @unique
  description     String?

  books           Book[]

  isActive        Boolean         @default(true)
  deletedAt       DateTime?

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

model Borrowing {
  id              String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  userId          String          @db.Uuid
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  bookCopyId      String          @db.Uuid
  bookCopy        BookCopy        @relation(fields: [bookCopyId], references: [id], onDelete: Cascade)

  status          BorrowingStatus @default(ACTIVE)
  borrowedAt      DateTime
  dueDate         DateTime
  returnedAt      DateTime?

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([userId])
  @@index([bookCopyId])
  @@index([status])
}

model Review {
  id              String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  userId          String          @db.Uuid
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  bookId          String          @db.Uuid
  book            Book            @relation(fields: [bookId], references: [id], onDelete: Cascade)

  rating          Int
  content         String?

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@unique([userId, bookId])

  @@index([userId])
  @@index([bookId])
}


