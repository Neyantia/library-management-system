{
  "name": "library-management-system",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --config jest.config.cjs",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watchAll --maxWorkers=1 --config jest.config.cjs",
    "test:cov": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage --config jest.config.cjs",
    "test:exp": "node --experimental-vm-modules node_modules/.bin/jest",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:int": "node --experimental-vm-modules node_modules/jest/bin/jest.js --runInBand --config jest.integration.cjs",
    "test:int:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watchAll --maxWorkers=1 --config jest.integration.cjs",
    "test:int:full": "npm run db:test:migrate && npm run test:int",
    "test:e2e": "node --experimental-vm-modules node_modules/jest/bin/jest.js --runInBand  --config jest.e2e.cjs",
    "test:e2e:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --detectOpenHandles --watchAll --config jest.e2e.cjs",
    "test:e2e:full": "npm run db:test:migrate && npm run test:e2e",
    "db:dev:migrate": "dotenv -e .env.development -- prisma migrate dev",
    "db:generate": "prisma generate",
    "db:dev:setup": "npm run db:dev:migrate && npm run db:generate",
    "db:dev:seed": "dotenv -e .env.development -- prisma db seed",
    "db:dev:reset": "dotenv -e .env.development -- prisma migrate reset --force",
    "db:test:migrate": "dotenv -e .env.test -- prisma migrate deploy",
    "db:test:seed": "dotenv -e .env.test -- prisma db seed",
    "db:test:reset": "dotenv -e .env.test -- prisma migrate reset --force"
  },
  "dependencies": {
    "@nestjs/axios": "^4.0.1",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/terminus": "^11.1.1",
    "@nestjs/throttler": "^6.5.0",
    "@node-rs/argon2": "^2.0.2",
    "@prisma/client": "^7.4.1",
    "@types/passport-jwt": "^4.0.1",
    "axios": "^1.13.6",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.4",
    "cookie-parser": "^1.4.7",
    "helmet": "^8.1.0",
    "jest-util": "^30.2.0",
    "joi": "^18.0.2",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "prisma-erd-generator": "^2.4.2",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.1.16",
    "@prisma/adapter-pg": "^7.4.2",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.19.13",
    "@types/passport-local": "^1.0.38",
    "@types/pg": "^8.18.0",
    "@types/supertest": "^6.0.2",
    "dotenv": "^17.3.1",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "jest": "^29.7.0",
    "pg": "^8.19.0",
    "prettier": "^3.4.2",
    "prisma": "^7.4.1",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.4.6",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.20.0"
  },
  "type": "module"
}
